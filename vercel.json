{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["frontend/dist/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "backend/src/server.js" }
  ]
}
